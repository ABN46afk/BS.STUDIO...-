-- ===== GHOST MODE =====
local ghostConnections = {}
local ghostParts = {}
local ghostTrails = {}
local ghostParticles = {}

local function ApplyGhostMode()
    if not GhostModeEnabled then
        for _, part in pairs(ghostParts) do
            if part and part:IsA("BasePart") then
                part.Transparency = 0
                if part:FindFirstChild("GhostGlow") then
                    part.GhostGlow:Destroy()
                end
            end
        end
        ghostParts = {}
        for _, conn in pairs(ghostConnections) do
            conn:Disconnect()
        end
        ghostConnections = {}
        return
    end
    
    local character = LocalPlayer.Character
    if not character then return end
    
    for _, part in pairs(character:GetDescendants()) do
        if part:IsA("BasePart") then
            part.Transparency = 1
            
            local glow = Instance.new("BillboardGui")
            glow.Name = "GhostGlow"
            glow.Size = UDim2.new(0, 50, 0, 50)
            glow.AlwaysOnTop = true
            glow.StudsOffset = Vector3.new(0, 0, 0)
            glow.Parent = part
            
            local frame = Instance.new("Frame")
            frame.Size = UDim2.new(1, 0, 1, 0)
            frame.BackgroundColor3 = GhostNeonColor
            frame.BackgroundTransparency = 0.1
            frame.BorderSizePixel = 0
            frame.Parent = glow
            
            table.insert(ghostParts, part)
        end
    end
    
    local conn = character.ChildAdded:Connect(function(child)
        task.wait(0.1)
        ApplyGhostMode()
    end)
    table.insert(ghostConnections, conn)
end

