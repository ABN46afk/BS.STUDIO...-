local function CopySkin(targetUsername)
    local targetPlayer = nil
    for _, player in pairs(Players:GetPlayers()) do
        if string.lower(player.Name) == string.lower(targetUsername) then
            targetPlayer = player
            break
        end
    end
    
    if not targetPlayer then
        WindUI:Notify({Title = "Skin Changer", Content = "Spieler nicht gefunden!", Duration = 3})
        return
    end
    
    local targetChar = targetPlayer.Character
    local localChar = LocalPlayer.Character
    if not targetChar or not localChar then 
        WindUI:Notify({Title = "Skin Changer", Content = "Charakter nicht gefunden!", Duration = 3})
        return
    end
    
    for _, child in pairs(localChar:GetChildren()) do
        if child:IsA("Accessory") or child:IsA("Shirt") or child:IsA("Pants") or child:IsA("ShirtGraphic") or child:IsA("Hat") or child:IsA("Clothing") then
            child:Destroy()
        end
    end
    
    for _, child in pairs(targetChar:GetChildren()) do
        if child:IsA("Accessory") or child:IsA("Hat") then
            local newAccessory = child:Clone()
            newAccessory.Parent = localChar
            pcall(function()
                newAccessory.Handle:BreakJoints()
            end)
            task.wait(0.05)
        end
    end
    
    local shirt = targetChar:FindFirstChild("Shirt")
    local pants = targetChar:FindFirstChild("Pants")
    local shirtGraphic = targetChar:FindFirstChild("ShirtGraphic")
    
    if shirt then shirt:Clone().Parent = localChar end
    if pants then pants:Clone().Parent = localChar end
    if shirtGraphic then shirtGraphic:Clone().Parent = localChar end
    
    local humanoid = localChar:FindFirstChild("Humanoid")
    if humanoid then humanoid:ApplyDescription() end
    
    WindUI:Notify({Title = "Skin Changer", Content = "Kompletter Skin von " .. targetUsername .. " kopiert!", Duration = 3})
end

